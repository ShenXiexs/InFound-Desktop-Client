{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "env.d.ts",
    "src/renderer/*.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts",
    "src/common/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@common/*": [
        "src/common/*"
      ],
      "@renderer/*": [
        "src/renderer/src/*"
      ]
    },
    "types": [
      "unplugin-icons/types/vue"
    ]
  }
}
